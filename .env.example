# ─── Database ────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=store_intelligence
POSTGRES_USER=retail_admin
POSTGRES_PASSWORD=retail_secret

DATABASE_URL=postgresql://retail_admin:retail_secret@postgres:5432/store_intelligence

# ─── API ─────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
LOG_LEVEL=INFO

# ─── Pipeline ────────────────────────────────────────────────────
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.35
YOLO_IOU=0.45
TRACKER_MAX_AGE=30
TRACKER_MIN_HITS=3
REENTRY_GAP_SECONDS=30
GROUP_ENTRY_WINDOW_SECONDS=2
GROUP_ENTRY_MIN_SIZE=3
ENTRY_LINE_Y_RATIO=0.85
EXIT_LINE_Y_RATIO=0.15

# ─── Dashboard ───────────────────────────────────────────────────
STREAMLIT_PORT=8501
API_BASE_URL=http://api:8000
